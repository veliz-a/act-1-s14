# Plantilla. Completa con tus credenciales reales.
# Este archivo NO debe subirse al repo (ya está en .gitignore).
# En Streamlit Cloud, pega este mismo contenido (con tus datos) en:
# App settings -> Secrets

SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "tu_anon_key_aqui"

MONGO_URI = "mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority"

B2_KEY_ID = "tu_key_id"
B2_APPLICATION_KEY = "tu_application_key"
B2_BUCKET_NAME = "nombre-de-tu-bucket"
B2_ENDPOINT = "https://s3.us-west-002.backblazeb2.com"
